[Unit]
Description=Helyx — tmux sessions + admin daemon
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=forking
User=%i
WorkingDirectory=/home/%i/bots/helyx
ExecStartPre=/home/%i/.local/bin/helyx up
ExecStart=/usr/bin/env bun /home/%i/bots/helyx/scripts/admin-daemon.ts
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
